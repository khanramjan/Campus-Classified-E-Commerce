{
  "name": "campus-classified-ecommerce",
  "version": "1.0.0",
  "type": "module",
  "description": "Campus Classified E-Commerce Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "cd server && npm start",
    "dev": "cd server && npm run dev",
    "build": "npm run install-all && cd client && npm run build",
    "install-server": "cd server && npm install",
    "install-client": "cd client && npm install",
    "install-all": "npm run install-server && npm run install-client",
    "vercel-build": "npm run install-all && cd client && npm run build",
    "netlify-build": "npm run install-all && cd client && npm run build"
  },
  "keywords": ["ecommerce", "campus", "classified", "bidding"],
  "author": "JUST",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "resend": "^3.5.0",
    "serverless-http": "^3.2.0",
    "stripe": "^16.12.0"
  }
}